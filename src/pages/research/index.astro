---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.year - a.data.year);
---

<BaseLayout title="Research - Anyi Liu">
  <div class="page-header">
    <h1>Research Interests</h1>
  </div>

  <section class="section">
    <div class="prose">
      <p>
        Information security, artificial intellegence, Cloud, IoT, and distributed system security, intrusion detection and prevention, digital forensics, malware analysis and defense, steganography, and privacy.
      </p>
    </div>
  </section>

  <section class="section">
    <SectionHeader title="Selected Publications" href="#" linkText="" />
    <div class="publications">
      <div class="pub-category">
        <h3>Journal</h3>
        <ol>
            <li>Shengmin Xu, Jianting Ning, Yingjiu Li, Guowen Xu, Xinyi Huang, Robert H. Deng, and <strong>Anyi Liu</strong>. Lightweight and Expressive Bilateral Access Control for Internet-of-Things in Cloud-Fog Computing. <em>IEEE Transactions on Dependable and Secure Computing</em>, 2020.</li>
            <li><strong>Anyi Liu</strong>, Huirong Fu, Yuan Hong, Jigang Liu, and Yingjiu Li. LiveForen: Ensuring Live Forensic Integrity in the Cloud. <em>IEEE Transactions on Information Forensics and Security</em>. Vol.14, No.10, 2019, pages 2749 - 2764.</li>
            <li><strong>Anyi Liu</strong>, Ali Alqazzaz, Hua Ming, and Balakrishnan Dharmalingam. IoTVerif: Automatic Verification of SSL/TLS Certificate for IoT Applications. <em>IEEE Access</em>. 2019.</li>
            <li><strong>Anyi Liu</strong>, Jim Chen, and Harry Wechsler. Real-time Timing Channel Detection in an Software-Defined Networking Virtual Environment. <em>Intelligent Information Management</em>. Vol.7 No.6, 2015.</li>
        </ol>
      </div>

      <div class="pub-category">
        <h3>Conference</h3>
        <ol>
            <li>Muhammad Anas Raza, Mohammad Wardat, <strong>Anyi Liu</strong>. DeepTrAnS: Mixer-based Unsupervised Time Series Anomaly Detection for Servers. <em>5th Intelligent Cybersecurity Conference (ICSC 2025)</em>. 2025.</li>
            <li>Balakrishnan Dharmalingam, Brett Piggott, Guohuan Feng, Rajdeep Mukherjee, and <strong>Anyi Liu</strong>. Areo-LLM: A Distributed Framework for Secure UAV Communication and Intelligent Decision-Making. <em>IEEE ICCCN’24</em>. 2024.</li>
            <li><strong>Anyi Liu</strong>, Yuan Cheng, Bruce Maxim, and Dorothy Yuan. Exploring Cybersecurity Hands-on Labs in Pervasive Computing. <em>ASEE’24</em>. 2024.</li>
            <li>Brett Piggott, Siddhant Patil, Guohuan Feng, Ibrahim Odat, Rajdeep Mukherjee, Balakrishnan Dharmalingam, and <strong>Anyi Liu</strong>. Net-GPT: A LLM-Empowered Man-in-the-Middle Chatbot for Unmanned Aerial Vehicle. <em>8th ACM/IEEE Symposium on Edge Computing</em>. 2023.</li>
            <li><strong>Anyi Liu</strong> and Guangzhi Qu. H-Verifier: Verifying Confidential System State with Delegated Sandboxes. <em>Science of Cyber Security (SciSec’18)</em>. 2018.</li>
            <li><strong>Anyi Liu</strong>, Dong Han, and Huirong Fu. ReScuE: A Cloud-based System for Cybersecurity Education and Training. <em>CISSE’18</em>. 2018.</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionHeader title="Grants & Scholarships" href="#" linkText="" />
    <ul class="grants">
      <li><strong>Enhancing AI Accountability and Security in Industrial Autonomous Systems through Advanced Forensics.</strong> MSU Innovation Center ADVANCE Grant. 2024 - 2025. Role: PI.</li>
      <li><strong>Yoda: Building Personalized Educational Experience with AIGC and LLMs.</strong> Oakland University URC. Summer 2024. Role: PI.</li>
      <li><strong>Reinforcing Resource-Constrained UAV with High-performance and Scalable LLM Cohorts.</strong> NASA grant #80NSSC20M0124. 2024 - 2025. Role: PI.</li>
      <li><strong>Building Cybersecurity Capacity in Pervasive Computing.</strong> NSF Award#1723707. 2016 - 2019. Role: PI.</li>
      <li><strong>Cyber Threat Intelligence Sharing and Correlation against Advanced Cyber Intrusions.</strong> NASA grant #NNX15AJ20H. 2017 - 2020. Role: PI.</li>
      <li><strong>DHS/NSA CAE-CD 4Y Center.</strong> 2018 - 2023 designation. Role: Co-PI.</li>
      <li><strong>NSF/NSA GenCyber Teacher’s camp.</strong> 2018. Role: Instructor.</li>
      <li><strong>NSF REU programs.</strong> 2019 - 2022. Role: Co-PI.</li>
    </ul>
  </section>

  <section class="section projects-section-spacing">
    <SectionHeader title="Projects" href="/research/projects" linkText="" />
    <ProjectGrid>
      {sortedProjects.map((project) => (
        <ProjectCard
          title={project.data.title}
          summary={project.data.summary}
          year={project.data.year}
          category={project.data.category}
          slug={project.slug}
          tags={project.data.tags}
        />
      ))}
    </ProjectGrid>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-8);
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: var(--space-2);
  }

  .publications {
    font-size: 1rem;
    color: var(--color-text);
  }

  .pub-category {
    margin-bottom: var(--space-6);
  }

  .pub-category h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .publications ol {
    padding-left: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .publications li {
    line-height: 1.5;
  }

  .grants {
    list-style: disc outside;
    padding-left: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    font-size: 1rem;
    color: var(--color-text);
  }

  .projects-section-spacing {
    margin-top: var(--space-8);
  }
</style>
