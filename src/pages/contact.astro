---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - Anyi Liu">
  <div class="contact-container">
    <h1>Contact</h1>
    
    <p class="intro">
      I am always open to discussing new research collaborations, speaking opportunities, or consulting work regarding AI safety and system security.
    </p>

    <div class="contact-details">
      <div class="method">
        <h3>Email</h3>
        <p><a href="mailto:anyiliu@oakland.edu">anyiliu@oakland.edu</a></p>
      </div>

      <div class="method">
        <h3>Office</h3>
        <p>
          526 Engineering Center<br>
          2200 N. Squirrel Road<br>
          Rochester, MI 48309-4478
        </p>
      </div>

      <div class="method">
        <h3>Social</h3>
        <ul class="social-links">
          <li><a href="https://github.com/anyiliu-mi">GitHub</a></li>
          <li><a href="#">Google Scholar</a></li> <!-- Placeholder -->
          <li><a href="#">LinkedIn</a></li> <!-- Placeholder -->
        </ul>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-container {
    max-width: 65ch;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: var(--space-6);
  }

  .intro {
    font-size: 1.25rem;
    margin-bottom: var(--space-8);
  }

  .contact-details {
    display: grid;
    gap: var(--space-8);
  }

  h3 {
    font-size: 1rem;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
  }

  p, li {
    font-size: 1.125rem;
  }

  .social-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-4);
  }
</style>
