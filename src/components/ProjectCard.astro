---
interface Props {
  title: string;
  summary: string;
  year: number;
  category: string;
  slug: string;
  tags?: string[];
}

const { title, summary, year, category, slug, tags } = Astro.props;
---

<article class="project-card">
  <div class="meta">
    <span class="category">{category}</span>
    <span class="year">{year}</span>
  </div>
  
  <h3>
    <a href={`/projects/${slug}`}>{title}</a>
  </h3>
  
  <p class="summary">{summary}</p>

  {tags && (
    <ul class="tags">
      {tags.slice(0, 3).map((tag) => (
        <li>{tag}</li>
      ))}
    </ul>
  )}
</article>

<style>
  .project-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: var(--space-5);
    border-radius: var(--radius-sm);
    transition: box-shadow 0.2s, transform 0.2s;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .project-card:hover {
    box-shadow: var(--shadow-sm);
    border-color: var(--color-muted);
    transform: translateY(-2px);
  }

  .meta {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    margin-bottom: var(--space-3);
  }

  h3 {
    font-family: var(--font-sans); /* Clean sans for card titles */
    font-size: 1.25rem;
    margin-bottom: var(--space-2);
  }

  h3 a {
    color: var(--color-text);
    border: none;
  }

  h3 a::after {
    content: '';
    position: absolute;
    inset: 0;
  }

  .summary {
    font-size: 0.9375rem;
    color: var(--color-muted);
    margin-bottom: var(--space-4);
    flex-grow: 1;
    line-height: 1.5;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .tags li {
    font-size: 0.75rem;
    color: var(--color-muted);
    background-color: var(--color-bg);
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }
</style>
