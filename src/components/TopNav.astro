---
import { useState } from 'preact/hooks';

const links = [
  { text: 'Home', href: '/' },
  { text: 'Teaching', href: '/teaching' },
  { text: 'Research', href: '/research' },
  { text: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<nav class="top-nav">
  <div class="container">
    <a href="/" class="site-title">Anyi Liu</a>
    
    <button class="menu-toggle" aria-label="Toggle Menu" id="menu-toggle">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>

    <div class="nav-menu" id="nav-menu">
      <ul class="nav-links">
        {links.map((link) => (
          <li>
            <a 
              href={link.href} 
              class:list={[{ active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
            >
              {link.text}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</nav>

<script>
  const menuToggle = document.getElementById('menu-toggle');
  const navMenu = document.getElementById('nav-menu');

  if (menuToggle && navMenu) {
    menuToggle.addEventListener('click', () => {
      navMenu.classList.toggle('open');
    });
  }
</script>

<style>
  .top-nav {
    display: none;
    padding: var(--space-4);
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 100%;
    margin: 0 auto;
  }

  .site-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .menu-toggle {
    background: none;
    border: none;
    color: var(--color-text);
    cursor: pointer;
    padding: var(--space-2);
  }

  .nav-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: var(--color-background);
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-4);
    display: none;
  }

  .nav-menu.open {
    display: block;
  }

  .nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-links li {
    margin-bottom: var(--space-2);
  }

  .nav-links a {
    text-decoration: none;
    color: var(--color-muted);
    font-size: 1rem;
    display: block;
    padding: var(--space-2) 0;
  }

  .nav-links a:hover,
  .nav-links a.active {
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .top-nav {
      display: block;
    }
  }
</style>
