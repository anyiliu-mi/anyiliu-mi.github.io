---
const year = new Date().getFullYear();
---

<footer>
  <p>&copy; {year} Anyi Liu. Built with Astro.</p>
  
  <div class="socials">
    <a href="https://github.com/anyiliu-mi" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="mailto:anyiliu@oakland.edu">Email</a>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-16);
    padding-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    font-size: 0.875rem;
    color: var(--color-muted);
  }

  .socials {
    display: flex;
    gap: var(--space-4);
  }

  @media (min-width: 640px) {
    footer {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
